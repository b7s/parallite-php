{
    "name": "parallite/parallite-php",
    "description": "Standalone PHP client for Parallite - Execute PHP closures in true parallel",
    "version": "1.1.0",
    "type": "library",
    "keywords": ["parallel", "php", "go", "laravel", "async", "concurrency", "parallite", "closure", "multiprocessing"],
    "license": "MIT",
    "authors": [
        {
            "name": "Bruno Tenorio",
            "email": "b7s@outlook.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "ext-sockets": "*",
        "opis/closure": "^4.0"
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-type-coverage": "^4.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Parallite\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/parallite-install",
        "bin/parallite-update"
    ],
    "scripts": {
        "post-install-cmd": [
            "@parallite:install"
        ],
        "post-update-cmd": [
            "@parallite:update"
        ],
        "parallite:install": "php bin/parallite-install",
        "parallite:update": "php bin/parallite-update",
        "test": [
            "@test:type-coverage",
            "@test:unit",
            "@test:types"
        ],
        "test:type-coverage": "@php vendor/bin/pest --type-coverage --min=100",
        "test:types": "@php vendor/bin/phpstan analyse --memory-limit=2G",
        "test:unit": "XDEBUG_MODE=coverage php vendor/bin/pest",
        "test:coverage": "XDEBUG_MODE=coverage php vendor/bin/pest --coverage --min=90"
    },
    "config": {
        "sort-packages": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
